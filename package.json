{
  "name": "sistematriunfo01",
  "version": "1.0.0",
  "description": "Triunfo System - Gestao de Frota",
  "main": "server/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server/server.js",

    "postinstall": "npx prisma generate --schema server/prisma/schema.prisma",

    "migrate:deploy": "npx prisma migrate deploy --schema server/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate deploy --schema server/prisma/schema.prisma",

    "backup": "node scripts/backup-db.js",
    "health-check": "node scripts/health-check.js",
    "deploy:safe": "npm run backup && npm run prisma:migrate && npm start",

    "dev": "node server/server.js",

    "prisma:status": "npx prisma migrate status --schema server/prisma/schema.prisma --env-file server/.env",
    "prisma:studio": "npx prisma studio --schema server/prisma/schema.prisma --env-file server/.env",
    "prisma:generate": "npx prisma generate --schema server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0"
  }
}
